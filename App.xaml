<Application x:Class="AutoTransfer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentColor">#FF2563EB</Color>
            <Color x:Key="AccentDarkColor">#FF1D4ED8</Color>
            <Color x:Key="SurfaceColor">#FFF8FAFC</Color>
            <Color x:Key="BorderColor">#FFE2E8F0</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FF64748B" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

<Window x:Class="AutoTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoTransfer - Test Tools"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#FFF1F5F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Color x:Key="AccentColor">#FF2563EB</Color>
        <Color x:Key="AccentDarkColor">#FF1D4ED8</Color>
        <Color x:Key="SurfaceColor">#FFF8FAFC</Color>
        <Color x:Key="BorderColor">#FFE2E8F0</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF64748B" />
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="24"
                          ShadowDepth="6"
                          Color="#220F172A"
                          Opacity="0.25" />
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FF0F172A"
                CornerRadius="24"
                Padding="24"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="AutoTransfer"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           Margin="0,0,0,8" />
                <TextBlock Text="Màn hình test công cụ tự động hóa"
                           Foreground="#FFCBD5E1"
                           FontSize="15"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24" />

                <Border Background="#14FFFFFF" CornerRadius="16" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Luồng test" Foreground="#FF93C5FD" FontWeight="SemiBold" />
                        <TextBlock Text="1. Chụp màn hình" Foreground="White" Margin="0,6,0,0" />
                        <TextBlock Text="2. Chọn vùng template" Foreground="White" />
                        <TextBlock Text="3. Tìm ảnh và click" Foreground="White" />
                        <TextBlock Text="4. Gửi text thử" Foreground="White" />
                    </StackPanel>
                </Border>

                <Border Background="#14FFFFFF" CornerRadius="16" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Ảnh mẫu hiện tại" Foreground="#FF93C5FD" FontWeight="SemiBold" />
                        <TextBlock x:Name="TemplatePathText"
                                   Text="Chưa chọn"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#14FFFFFF" CornerRadius="16" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Trạng thái" Foreground="#FF93C5FD" FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText"
                                   Text="Sẵn sàng"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,0" />
                        <TextBlock x:Name="PointText"
                                   Text="Điểm tìm được: chưa có"
                                   Foreground="#FFE2E8F0"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="White"
                CornerRadius="24"
                Padding="24"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Bảng điều khiển test"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock Text="Dùng màn hình này để kiểm tra OpenCvSharp, InputSimulatorPlus và KAutoHelper"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="14"
                               Margin="0,6,0,0" />
                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="0,20,0,16">
                    <Button Style="{StaticResource PrimaryButton}" Content="Chụp màn hình" Click="CaptureScreen_Click" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Chọn ảnh mẫu" Click="SelectTemplate_Click" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Chọn vùng template" Click="CropTemplate_Click" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Tìm ảnh mẫu" Click="FindTemplate_Click" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Click điểm tìm được" Click="ClickFoundPoint_Click" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Gửi text thử" Click="SendTestText_Click" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Xóa log" Click="ClearLog_Click" />
                </WrapPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Preview ảnh chụp"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <Border Background="#FFFFFFFF" CornerRadius="12" BorderBrush="#FFE5E7EB" BorderThickness="1">
                                <Grid ClipToBounds="True">
                                    <Image x:Name="PreviewImage"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True" />
                                </Grid>
                            </Border>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Log"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <TextBox x:Name="LogBox"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Background="White"
                                     BorderBrush="#FFE5E7EB"
                                     Padding="12" />
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Mẹo: chọn vùng vừa đủ quanh nút, tránh kéo quá nhiều nền xung quanh để nhận diện chính xác hơn."
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="Đóng"
                            Width="110"
                            Margin="10,0,0,0"
                            Click="Close_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

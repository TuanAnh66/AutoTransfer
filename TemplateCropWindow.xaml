<Window x:Class="AutoTransfer.TemplateCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn vùng template"
        Width="1000"
        Height="760"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized" ResizeMode="CanResize"
        Background="#FFF1F5F9"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Color x:Key="AccentColor">#FF2563EB</Color>
        <Color x:Key="AccentDarkColor">#FF1D4ED8</Color>
        <Color x:Key="BorderColor">#FFE2E8F0</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Chọn vùng template"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#FF0F172A" />
            <TextBlock Text="Kéo chuột để khoanh đúng phần nút cần nhận diện."
                       Foreground="#FF64748B"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="10">
            <Grid x:Name="ImageArea"
                  Background="#FFF8FAFC"
                  ClipToBounds="True">
                <Viewbox x:Name="ImageViewport"
                         Stretch="Uniform"
                         StretchDirection="Both"
                         ClipToBounds="True">
                    <Canvas x:Name="ImageCanvas"
                            Background="Transparent"
                            Cursor="Cross"
                            MouseLeftButtonDown="ImageCanvas_MouseLeftButtonDown"
                            MouseMove="ImageCanvas_MouseMove"
                            MouseLeftButtonUp="ImageCanvas_MouseLeftButtonUp">
                        <Image x:Name="PreviewImage"
                               Stretch="None"
                               SnapsToDevicePixels="True"
                               IsHitTestVisible="False" />
                        <Rectangle x:Name="SelectionRect"
                                   Stroke="#FF2563EB"
                                   StrokeThickness="2"
                                   Fill="#332563EB"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False" />
                    </Canvas>
                </Viewbox>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HintText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#FF64748B"
                       Text="Chưa chọn vùng nào." />

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Hủy" Width="110" Click="Cancel_Click" />
                <Button Style="{StaticResource PrimaryButton}" Content="Dùng vùng này" Width="140" Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

